# Content-Ops Console 环境变量配置

# 应用地址（用于 Composio 回调）
# 部署到生产环境时，请修改为实际的服务器地址
# 例如：http://14.103.210.113:3005
APP_URL=http://localhost:3005
NEXT_PUBLIC_APP_URL=http://localhost:3005

# 数据库路径（可选，默认使用当前目录下的 content-ops.db）
# DATABASE_PATH=/path/to/content-ops.db

# JWT 密钥（生产环境请修改为随机字符串）
JWT_SECRET=your-secret-key-change-in-production

# Composio API Key（在系统设置中配置，或在此处设置）
# COMPOSIO_API_KEY=your-composio-api-key
